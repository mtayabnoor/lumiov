# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.vite

# --- Build Outputs ---
# These will ignore folders in root AND all subfolders (frontend, backend, electron)
dist/
release/
build/
out/
bin/
obj/

# --- Environment & Security ---
.env
.env.*
*.pfx
*.p12
*.pem
*.key
*.cert

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- Personal Scripts ---
commands.txt
kubernetes_yaml_files/*

# --- Google Antigravity - Ignore dynamic agent artifacts ---
.agent/artifacts/
.agent/browser_recordings/
.agent/screenshots/
.agent/logs/
.agent/execution_logs/
.agent/cache/
.agent/task_lists/
.agent/plans/
*.local.md  # Ignore any private/local rule overrides