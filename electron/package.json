{
  "name": "lumiov",
  "version": "1.7.0-rc.2",
  "description": "Lumiov Kubernetes Manager",
  "author": "mtayabnoor",
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder",
    "package:publish": "electron-builder --publish always",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "build": {
    "appId": "com.lumiov.app",
    "productName": "Lumiov",
    "artifactName": "${productName}-Setup-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "mtayabnoor",
        "repo": "lumiov",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../frontend/public/lumiov.ico"
    },
    "nsis": {
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "../frontend/public/splash.html",
        "to": "frontend/public/splash.html"
      },
      {
        "from": "../frontend/public/lumiov.ico",
        "to": "frontend/public/lumiov.ico"
      },
      {
        "from": "../backend/dist",
        "to": "backend"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.55.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ws": "8.20.0"
  }
}
